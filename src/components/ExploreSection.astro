---
const brandName = import.meta.env.PUBLIC_BRAND_NAME || 'SuperRank';
---

<section class="relative overflow-hidden py-20 sm:py-28">
  <div class="absolute inset-0 bg-gradient-to-r from-accent-blue-light/60 via-sky-100/40 to-indigo-100/50 blur-sm" aria-hidden="true"></div>
  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="rounded-2xl border border-white/50 bg-white/90 p-8 shadow-xl backdrop-blur-sm sm:p-12 lg:flex lg:items-center lg:justify-between lg:gap-12">
      <div class="lg:w-1/2">
        <h2 class="text-2xl font-bold text-gray-900 sm:text-3xl">Explore Our AI-Generated</h2>
        <p class="mt-4 text-gray-600">
          Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.
        </p>
        <a href="#" class="mt-6 inline-flex items-center gap-2 rounded-lg bg-blue-600 px-6 py-3.5 text-base font-semibold text-white shadow-sm transition hover:bg-blue-700">
          Learn More
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
      <div class="mt-10 space-y-4 lg:mt-0 lg:w-1/2">
        <a href="#" class="flex items-center justify-between gap-4 rounded-2xl border border-gray-100 bg-white p-5 shadow-[0_4px_14px_rgba(0,0,0,0.08)] transition hover:shadow-[0_8px_24px_rgba(0,0,0,0.12)]">
          <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-gray-100">
            <svg class="h-5 w-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
          </div>
          <span class="flex-1 text-center font-bold text-gray-900">SEO Content Ideas</span>
          <svg class="h-5 w-5 shrink-0 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
        <a href="#" class="flex items-center justify-between gap-4 rounded-2xl border border-gray-100 bg-white p-5 shadow-[0_4px_14px_rgba(0,0,0,0.08)] transition hover:shadow-[0_8px_24px_rgba(0,0,0,0.12)]">
          <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-gray-100">
            <svg class="h-5 w-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <span class="flex-1 text-center font-bold text-gray-900">AI-Powered Writing</span>
          <svg class="h-5 w-5 shrink-0 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
        <a href="#" class="flex items-center justify-between gap-4 rounded-2xl border border-gray-100 bg-white p-5 shadow-[0_4px_14px_rgba(0,0,0,0.08)] transition hover:shadow-[0_8px_24px_rgba(0,0,0,0.12)]">
          <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-gray-100">
            <svg class="h-5 w-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4v16" />
            </svg>
          </div>
          <span class="flex-1 text-center font-bold text-gray-900">Performance Tracking</span>
          <svg class="h-5 w-5 shrink-0 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
