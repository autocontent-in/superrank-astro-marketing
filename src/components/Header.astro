---
import logoImage from '../assets/superrank_logo.png';

const brandName = import.meta.env.PUBLIC_BRAND_NAME || 'SuperRank';
---

<header
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 bg-transparent transition-[background,backdrop-filter,border-color] duration-300"
>
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
    <nav class="hidden items-center gap-8 md:flex">
      <a href="/" class="flex items-center gap-2">
        <img
          src={logoImage.src}
          width={logoImage.width}
          height={logoImage.height}
          alt=""
          class="h-8 w-auto shrink-0 rounded-md object-contain"
          loading="eager"
          decoding="async"
        />
        <span class="text-xl font-bold text-gray-900">{brandName}</span>
      </a>
      <a href="#" class="text-sm font-medium text-gray-600 hover:text-gray-900 transition-colors">Home</a>
      <a href="#features" class="text-sm font-medium text-gray-600 hover:text-gray-900 transition-colors">Features</a>
      <a href="#pricing" class="text-sm font-medium text-gray-600 hover:text-gray-900 transition-colors">Pricing</a>
      <a href="#contact" class="text-sm font-medium text-gray-600 hover:text-gray-900 transition-colors">Contact</a>
    </nav>
    <div class="flex items-center gap-4">
      <a href="http://localhost:5173/login" class="rounded-lg border border-gray-300 bg-white px-4 py-2 text-sm font-semibold text-gray-700 shadow-sm transition hover:bg-gray-50">Log In</a>
      <a href="http://localhost:5173/signup" class="rounded-lg bg-blue-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-blue-700">Create Account</a>
    </div>
  </div>
</header>
<script>
  const navbar = document.getElementById('navbar');
  function updateNavbar() {
    if (window.scrollY > 10) {
      navbar?.classList.add('scrolled');
    } else {
      navbar?.classList.remove('scrolled');
    }
  }
  updateNavbar();
  window.addEventListener('scroll', updateNavbar);
</script>
<style>
  #navbar {
    background: transparent;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    border-bottom: 1px solid transparent;
  }

  #navbar.scrolled {
    background: linear-gradient(
      180deg,
      rgb(255 255 255 / 0.88) 0%,
      rgb(239 246 255 / 0.82) 100%
    );
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom-color: rgb(191 219 254 / 0.55);
  }
</style>
