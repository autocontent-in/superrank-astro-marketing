---
import { Loader } from "lucide-react";
import AgentAnalyticsStep from "./react/AgentAnalyticsStep";
import HowToStep2 from "./react/HowToStep2";
import HowToStep3 from "./react/HowToStep3";
import HowToStep4 from "./react/HowToStep4";
import KeywordCloudCard from "./react/KeywordCloudCard";
import WebsiteScoreStep from "./react/WebsiteScoreStep";

const brandName = import.meta.env.PUBLIC_BRAND_NAME || "SuperRank";
---

<section id="how-it-works" class="relative z-10 bg-white py-20 sm:py-28 -mt-48 sm:-mt-56 lg:-mt-64">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <h2
      class="text-center text-3xl font-bold tracking-tight text-gray-800 sm:text-4xl"
      style="line-height: 1.5;"
    >
      <span class="text-3xl"
        >How to boost your website's <span
          class="rounded px-1.5 bg-blue-500/35 text-gray-900">SEO</span
        ></span
      >
      <br />
      <span class="text-5xl"> with {brandName}</span>
    </h2>
    <div class="mt-16 grid gap-6 sm:grid-cols-1">
      <!-- Step 1 -->
      <article class="flex p-1 relative rounded-xl border border-gray-200">
        <div
          class="w-full pt-6 pl-6 bg-[linear-gradient(120deg,_#F7953310,_#F3705520,_#EF4E7B20,_#A166AB20,_#5073B820,_#1098AD20,_#F7953310,_#F3705520)] rounded-lg flex gap-10"
        >
          <div class="w-3/6 pb-6">
            <div class="mt-6">
              <h3 class="text-2xl font-bold text-gray-800 tracking-tight">
                Checks your website performance, SEO, GEO, traffic, and more
                with AI
              </h3>
              <p class="mt-6 text-base text-gray-500">
                We analyze your site for SEO health, content quality for Google
                E-E-A-T (experience, expertise, authoritativeness,
                trustworthiness), and traffic potential.
                <br />
                <br />
                You get a clear, actionable report with an overall score and specific
                recommendations so you know exactly what to fix and improve first.
              </p>
            </div>
          </div>
          <div class="flex w-4/6 flex-col">
            <WebsiteScoreStep client:load />
          </div>
        </div>
      </article>

      <!-- Step 2 -->
      <div class="w-full flex items-start gap-6">
        <div class="w-2/5 flex flex-col gap-6">
          <article class="flex p-1 relative rounded-xl border border-gray-200">
            <div
              class="w-full py-6 px-6 bg-gradient-to-b from-yellow-50 to-orange-100 rounded-lg flex flex-col"
            >
              <h3 class="text-2xl font-bold text-gray-800 tracking-tight">
                Performs keyword research
              </h3>
              <p class="mt-6 text-base text-gray-500">
                Our AI performs automatic keywords research to find the best
                keywords for your site.
              </p>
              <div class="mt-10">
                <KeywordCloudCard client:load />
              </div>
            </div>
          </article>
          <article class="flex p-1 relative rounded-xl border border-gray-200">
            <div
              class="w-full pt-6 px-6 bg-gradient-to-tr from-sky-50 to-white rounded-lg flex flex-col"
            >
              <h3 class="text-2xl font-bold text-gray-800 tracking-tight">
                AI creates the content
              </h3>
              <p class="mt-6 text-base text-gray-500">
                Our AI generates content tailored to your site's topics,
                keywords, and tone. It follows best practices, ensuring your
                content ranks well and engages your audience.
              </p>
              <div class="mt-10 flex flex-col">
                <div
                  class="flex flex-col border-t border-x border-gray-200 p-4 rounded-t-xl bg-white"
                >
                  <div class="flex items-center justify-between">
                    <div>
                      <h3 class="text-sm font-semibold text-gray-800">
                        How AI shaping the businesses
                      </h3>
                      <p class="text-sm text-gray-500">
                        for <span
                          class="font-medium underline decoration-gray-400 underline-offset-4 decoration-dashed"
                          >Business Blog</span
                        >
                      </p>
                    </div>
                    <button
                      class="flex space-x-2 items-center rounded-full bg-white px-4 py-2 text-sm font-medium border border-blue-400 text-blue-600"
                    >
                      <Loader className="w-4 h-4 animate-spin" />
                      <span class="text-sm font-semibold">Creating...</span>
                    </button>
                  </div>

                  <hr class="mt-4 mb-0 pb-0" />

                  <div class="grid grid-cols-2 mt-4 gap-10">
                    <div class="space-y-2">
                      <p class="mb-4 text-sm text-gray-600">Article</p>
                      <div class="h-3 w-full rounded bg-gray-200"></div>
                      <div class="h-3 w-full rounded bg-gray-200"></div>
                      <div class="h-3 w-4/5 rounded bg-gray-200"></div>
                    </div>
                    <div class="space-y-2">
                      <p class="mb-4 text-sm text-gray-600">Keywords</p>
                      <div class="flex space-x-2">
                        <div class="h-3 w-2/6 rounded bg-gray-200"></div>
                        <div class="h-3 w-2/6 rounded bg-gray-200"></div>
                        <div class="h-3 w-2/6 rounded bg-gray-200"></div>
                      </div>
                      <div class="flex space-x-2">
                        <div class="h-3 w-3/5 rounded bg-gray-200"></div>
                        <div class="h-3 w-2/5 rounded bg-gray-200"></div>
                      </div>
                      <div class="flex space-x-2">
                        <div class="h-3 w-2/5 rounded bg-gray-200"></div>
                        <div class="h-3 w-2/5 rounded bg-gray-200"></div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </article>
        </div>
        <div class="w-3/5 flex flex-col gap-6">
          <article class="flex p-1 relative rounded-xl border border-gray-200">
            <div
              class="w-full pt-6 px-6 pb-6 bg-gradient-to-tr from-pink-50 to-blue-50 rounded-lg flex flex-col"
            >
              <div class="w-full">
                <AgentAnalyticsStep client:load />
              </div>
            </div>
          </article>
          <article class="flex p-1 relative rounded-xl border border-gray-200 flex-1 min-h-0">
            <div
              class="w-full pt-6 px-6 pb-6 bg-gradient-to-br from-indigo-50 to-violet-50 rounded-lg flex flex-col"
            >
              <h3 class="text-2xl font-bold text-gray-800 tracking-tight">
                Export & act on insights
              </h3>
              <p class="mt-4 text-base text-gray-500">
                Download reports, share with your team, or connect to your
                workflow. Use the same metrics and recommendations to prioritize
                fixes and track progress over time.
              </p>
              <div class="mt-6 flex flex-wrap gap-3">
                <span
                  class="inline-flex items-center rounded-full bg-white/80 px-3 py-1.5 text-sm font-medium text-gray-700 border border-gray-200"
                >PDF report</span>
                <span
                  class="inline-flex items-center rounded-full bg-white/80 px-3 py-1.5 text-sm font-medium text-gray-700 border border-gray-200"
                >Share link</span>
                <span
                  class="inline-flex items-center rounded-full bg-white/80 px-3 py-1.5 text-sm font-medium text-gray-700 border border-gray-200"
                >Track over time</span>
              </div>
            </div>
          </article>
        </div>
      </div>
    </div>
  </div>
</section>
