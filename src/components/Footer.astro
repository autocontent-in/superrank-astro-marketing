---
const brandName = import.meta.env.PUBLIC_BRAND_NAME || 'SuperRank';
const tagline = import.meta.env.PUBLIC_TAGLINE || 'Boost your website\'s SEO, GEO and AEO with AI. Improve your business and brand visibility by 10x';
const currentYear = new Date().getFullYear();
---

<footer class="relative bg-white pt-12">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Top section: brand left, menu columns right -->
    <div class="flex flex-col gap-12 pb-12 md:flex-row md:items-start md:justify-between">
      <!-- Left: brand identity -->
      <div class="flex flex-col">
        <div class="flex items-center gap-3">
          <div class="flex flex-col">
            {brandName.split(' ').length > 1 ? (
              <>
                <span class="text-base font-bold leading-tight text-gray-800">{brandName.split(' ')[0]}</span>
                <span class="text-lg font-bold leading-tight text-gray-900">{brandName.split(' ').slice(1).join(' ')}</span>
              </>
            ) : (
              <span class="text-lg font-bold leading-tight text-gray-900">{brandName}</span>
            )}
          </div>
        </div>
        <p class="mt-4 max-w-xs text-sm text-gray-500">{tagline}</p>
      </div>

      <!-- Right: menu columns -->
      <nav class="grid grid-cols-2 gap-20 sm:grid-cols-4" aria-label="Footer navigation">
        <div>
          <h3 class="text-xs font-medium uppercase tracking-wider text-gray-400">Product</h3>
          <ul class="mt-3 space-y-2">
            <li><a href="#features" class="text-sm text-gray-600 hover:text-gray-900 transition">Features</a></li>
            <li><a href="#pricing" class="text-sm text-gray-600 hover:text-gray-900 transition">Pricing</a></li>
            <li><a href="#blog" class="text-sm text-gray-600 hover:text-gray-900 transition">Blog</a></li>
          </ul>
        </div>
        <div>
          <h3 class="text-xs font-medium uppercase tracking-wider text-gray-400">Follow us</h3>
          <ul class="mt-3 space-y-2">
            <li><a href="#" class="text-sm text-gray-600 hover:text-gray-900 transition">Showcase</a></li>
            <li><a href="#" class="text-sm text-gray-600 hover:text-gray-900 transition">Affiliates</a></li>
          </ul>
        </div>
        <div>
          <h3 class="text-xs font-medium uppercase tracking-wider text-gray-400">Company</h3>
          <ul class="mt-3 space-y-2">
            <li><a href="#" class="text-sm text-gray-600 hover:text-gray-900 transition">About</a></li>
            <li><a href="#" class="text-sm text-gray-600 hover:text-gray-900 transition">Contact</a></li>
            <li><a href="#" class="text-sm text-gray-600 hover:text-gray-900 transition">Testimonials</a></li>
          </ul>
        </div>
        <div>
          <h3 class="text-xs font-medium uppercase tracking-wider text-gray-400">Social</h3>
          <ul class="mt-3 space-y-2">
            <li><a href="#" class="text-sm text-gray-600 hover:text-gray-900 transition">Facebook</a></li>
            <li><a href="#" class="text-sm text-gray-600 hover:text-gray-900 transition">Twitter</a></li>
            <li><a href="#" class="text-sm text-gray-600 hover:text-gray-900 transition">Github</a></li>
          </ul>
        </div>
      </nav>
    </div>

    <!-- Bottom section: copyright left, legal links right -->
    <div class="flex flex-col gap-4 border-t border-gray-200 pt-8 sm:flex-row sm:items-center sm:justify-between">
      <p class="text-sm text-gray-500">© {brandName} {currentYear}. All Rights Reserved.</p>
      <div class="flex flex-wrap items-center space-x-4 text-sm text-gray-500">
        <a href="#" class="hover:text-gray-900 transition">Terms &amp; Conditions</a>
        <span aria-hidden="true">•</span>
        <a href="#" class="hover:text-gray-900 transition">Privacy Policy</a>
        <span aria-hidden="true">•</span>
        <a href="#" class="hover:text-gray-900 transition">Cookies</a>
      </div>
    </div>
  </div>
  <!-- Big fading brand name -->
  <div class="mt-16 overflow-hidden pt-8 pb-0" aria-hidden="true">
    <h2
      class="mb-0 text-center text-[clamp(4rem,18vw,14rem)] font-extrabold leading-none tracking-tighter text-gray-300"
      style="mask-image: linear-gradient(to bottom, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.2) 50%, transparent 100%); -webkit-mask-image: linear-gradient(to bottom, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.2) 50%, transparent 100%);"
    >
      {brandName}
    </h2>
  </div>
</footer>
